OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
ENABLE_LLM_ASSIST=true
OPENAI_TURN_UNDERSTANDING_ENABLED=true

CLOSER_NOTIFICATION_METHOD=console
CLOSER_NOTIFICATION_ENABLED=true
CLOSER_PHONE_NUMBER=<SET_ME>
ADMIN_USER=lual_admin
CLOSER_CONSOLE_LOG_PATH=artifacts/closer_notifications.log

WHATSAPP_MODE=stub
WHATSAPP_WEBHOOK_ENABLED=false
WHATSAPP_OUTBOUND_ENABLED=false
WHATSAPP_OUTBOUND_URL=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_SOURCE_NUMBER=
WHATSAPP_TIMEOUT_SECONDS=15
WHATSAPP_DISPATCH_LOG_PATH=artifacts/whatsapp_dispatch.log

STATE_STORAGE_DIR=artifacts/state
LIVE_API_LOG_PATH=artifacts/live_api_calls.jsonl
